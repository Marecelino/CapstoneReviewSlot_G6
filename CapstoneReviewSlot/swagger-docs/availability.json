                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LecturerAvailabilityDto"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LecturerAvailabilityDto"
                  }
                }
              }
            }
          }
