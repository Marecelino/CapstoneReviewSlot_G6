{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:5000",
  "IDENTITY_SERVICE_URL": "http://identity:80",
  "SESSION_SERVICE_URL": "http://session:80",
  "AVAILABILITY_SERVICE_URL": "http://availability:80",
  "REGISTRATION_SERVICE_URL": "http://registration:80",
  "ASSIGNMENT_SERVICE_URL": "http://assignment:80",
  "REPORT_SERVICE_URL": "http://report:80",
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/identity"
          }
        ]
      },
      "session": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/api/campaigns/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/campaigns"
          }
        ]
      },
      "session-groups": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/api/groups/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/groups"
          }
        ]
      },
      "session-groups-avail": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/api/groups/availability/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/groups/availability"
          }
        ]
      },
      "availability": {
        "ClusterId": "availability-cluster",
        "Match": {
          "Path": "/api/availability/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/availability"
          }
        ]
      },
      "registration": {
        "ClusterId": "registration-cluster",
        "Match": {
          "Path": "/api/preferences/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/preferences"
          }
        ]
      },
      "assignment": {
        "ClusterId": "assignment-cluster",
        "Match": {
          "Path": "/api/reviewassignment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/reviewassignment"
          }
        ]
      },
      "assignment-manage": {
        "ClusterId": "assignment-cluster",
        "Match": {
          "Path": "/api/assignment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/assignment"
          }
        ]
      },
      "reports": {
        "ClusterId": "report-cluster",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/reports"
          }
        ]
      },
      "availability-grpc": {
        "ClusterId": "availability-cluster",
        "Match": {
          "Path": "/Availability/{**catch-all}"
        }
      },
      "identity-grpc": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/Identity/{**catch-all}"
        }
      },
      "session-grpc": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/Session/{**catch-all}"
        }
      },
      "swagger-identity": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger-identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "swagger-session": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/swagger-session/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "swagger-availability": {
        "ClusterId": "availability-cluster",
        "Match": {
          "Path": "/swagger-availability/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "swagger-registration": {
        "ClusterId": "registration-cluster",
        "Match": {
          "Path": "/swagger-registration/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "swagger-assignment": {
        "ClusterId": "assignment-cluster",
        "Match": {
          "Path": "/swagger-assignment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "swagger-report": {
        "ClusterId": "report-cluster",
        "Match": {
          "Path": "/swagger-report/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://identity:80"
          }
        }
      },
      "session-cluster": {
        "Destinations": {
          "session": {
            "Address": "http://session:80"
          }
        }
      },
      "availability-cluster": {
        "Destinations": {
          "availability": {
            "Address": "http://availability:80"
          }
        }
      },
      "registration-cluster": {
        "Destinations": {
          "registration": {
            "Address": "http://registration:80"
          }
        }
      },
      "assignment-cluster": {
        "Destinations": {
          "assignment": {
            "Address": "http://assignment:80"
          }
        }
      },
      "report-cluster": {
        "Destinations": {
          "report": {
            "Address": "http://report:80"
          }
        }
      }
    }
  }
}